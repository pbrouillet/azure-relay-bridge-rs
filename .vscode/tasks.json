{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (debug)",
            "type": "cargo",
            "command": "build",
            "args": ["--workspace"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Build (release)",
            "type": "cargo",
            "command": "build",
            "args": ["--workspace", "--release"],
            "group": "build",
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Clippy",
            "type": "cargo",
            "command": "clippy",
            "args": ["--workspace", "--all-targets"],
            "group": "build",
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Format check",
            "type": "cargo",
            "command": "fmt",
            "args": ["--check"],
            "problemMatcher": []
        },
        {
            "label": "Test: All (workspace)",
            "type": "cargo",
            "command": "test",
            "args": ["--workspace"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Test: Unit only",
            "type": "cargo",
            "command": "test",
            "args": ["--workspace", "--lib"],
            "group": "test",
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Test: Integration (azure-relay)",
            "type": "cargo",
            "command": "test",
            "args": ["-p", "azure-relay", "--test", "*"],
            "group": "test",
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Test: E2E (bridge)",
            "type": "cargo",
            "command": "test",
            "args": ["-p", "azure-relay-bridge-rs", "--test", "bridge_integration_tests"],
            "group": "test",
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Test: Live integration (needs RELAY_CONNECTION_STRING)",
            "type": "cargo",
            "command": "test",
            "args": ["--workspace", "--", "--ignored"],
            "group": "test",
            "problemMatcher": ["$rustc"]
        }
    ]
}
